  "snortRules": [
    { "id": 1,  "sid": 1000001, "name": "ICMP Echo Reply",            "category": "icmp",      "isEnabled": true,  "isPassRule": false, "priority": 3, "description": "Detect ICMP echo replies on unauthorized hosts",                              "ruleText": "alert icmp any any -> $HOME_NET any (msg:\"ICMP Echo Reply\"; itype:0; sid:1000001;)", "createdAt": null, "updatedAt": null },
    { "id": 2,  "sid": 1000010, "name": "Modbus Write Single Coil",    "category": "modbus",    "isEnabled": true,  "isPassRule": false, "priority": 1, "description": "Modbus function 5 (write coil) from non-HMI source",                          "ruleText": "alert tcp !$HMI_NET any -> $PLC_NET 502 (msg:\"Modbus Write Coil\"; flow:to_server; content:\"|05|\"; offset:7; depth:1; sid:1000010;)", "createdAt": null, "updatedAt": null },
    { "id": 3,  "sid": 1000011, "name": "Modbus Force Multiple Coils", "category": "modbus",    "isEnabled": true,  "isPassRule": false, "priority": 1, "description": "Modbus function 15 (force multiple coils)",                                  "ruleText": "alert tcp any any -> $PLC_NET 502 (msg:\"Modbus Force Multiple Coils\"; flow:to_server; content:\"|0f|\"; offset:7; depth:1; sid:1000011;)", "createdAt": null, "updatedAt": null },
    { "id": 4,  "sid": 1000020, "name": "DNP3 from non-master",        "category": "dnp3",      "isEnabled": false, "isPassRule": false, "priority": 2, "description": "DNP3 traffic from a non-master IP",                                          "ruleText": "alert tcp !$MASTER_NET any -> any 20000 (msg:\"DNP3 from non-master\"; sid:1000020;)", "createdAt": null, "updatedAt": null },
    { "id": 5,  "sid": 1000030, "name": "FTP brute force",              "category": "auth",      "isEnabled": false, "isPassRule": false, "priority": 2, "description": "Repeated FTP login failures",                                                "ruleText": "alert tcp any any -> any 21 (msg:\"FTP brute force\"; content:\"530 Login\"; sid:1000030;)", "createdAt": null, "updatedAt": null },
    { "id": 6,  "sid": 1000040, "name": "Modbus port scan",             "category": "modbus",    "isEnabled": true,  "isPassRule": false, "priority": 1, "description": "Sweeping the 502/TCP port across the plant VLAN",                            "ruleText": "alert tcp any any -> $PLC_NET 502 (msg:\"Modbus port scan\"; threshold:type both, track by_src, count 10, seconds 60; sid:1000040;)", "createdAt": null, "updatedAt": null },
    { "id": 7,  "sid": 1000050, "name": "SSH from outside VLAN",        "category": "auth",      "isEnabled": true,  "isPassRule": false, "priority": 2, "description": "SSH attempts from outside the plant VLAN",                                   "ruleText": "alert tcp !$HOME_NET any -> $HOME_NET 22 (msg:\"SSH from outside VLAN\"; sid:1000050;)", "createdAt": null, "updatedAt": null },
    { "id": 8,  "sid": 1000060, "name": "Unauthorized HTTPS to PLC",    "category": "scan",      "isEnabled": false, "isPassRule": false, "priority": 3, "description": "HTTPS traffic to PLC web interface",                                         "ruleText": "alert tcp any any -> $PLC_NET 443 (msg:\"HTTPS to PLC\"; sid:1000060;)", "createdAt": null, "updatedAt": null },
    { "id": 9,  "sid": 1000070, "name": "ARP spoofing",                 "category": "spoof",     "isEnabled": true,  "isPassRule": false, "priority": 1, "description": "Suspicious ARP reply patterns",                                              "ruleText": "alert arp any any -> any any (msg:\"ARP spoofing\"; sid:1000070;)", "createdAt": null, "updatedAt": null },
    { "id": 10, "sid": 1000080, "name": "DNS exfiltration",             "category": "dns",       "isEnabled": false, "isPassRule": false, "priority": 2, "description": "Anomalously long DNS queries",                                               "ruleText": "alert udp any any -> any 53 (msg:\"DNS exfiltration\"; dsize:>200; sid:1000080;)", "createdAt": null, "updatedAt": null }
